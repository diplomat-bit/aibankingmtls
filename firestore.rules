rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Auth & Utilities
    function isSignedIn() { return request.auth != null && request.auth.uid != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.createdAt is string && data.createdAt.size() <= 30 &&
             (data.get('displayName', '') is string && data.get('displayName', '').size() <= 100) &&
             (data.get('email', '') is string && data.get('email', '').size() <= 200) &&
             (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 2000);
    }
    
    function isValidAccount(data) {
      return data.keys().hasAll(['userId', 'name', 'balance', 'type', 'currency']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.balance is number &&
             data.type is string && data.type.size() <= 50 &&
             data.currency is string && data.currency.size() <= 10;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'amount', 'description', 'category', 'date', 'type']) &&
             data.userId == request.auth.uid &&
             data.amount is number &&
             data.description is string && data.description.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.date is string && data.date.size() <= 30 &&
             data.type in ['debit', 'credit'];
    }

    match /_connection_test_/{docId} {
      allow read: if true;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && isOwner(userId);
      allow create: if isSignedIn() && isValidId(userId) && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && isValidId(userId) && isOwner(userId) && isValidUser(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'email']);
    }

    match /accounts/{accountId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(accountId) && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(accountId) && isValidAccount(incoming()) && exists(/databases/$(database)/documents/users/$(request.auth.uid));
      allow update: if isSignedIn() && isValidId(accountId) && existing().userId == request.auth.uid && isValidAccount(incoming()) && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isValidId(accountId) && existing().userId == request.auth.uid;
    }

    match /transactions/{transactionId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(transactionId) && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(transactionId) && isValidTransaction(incoming()) && exists(/databases/$(database)/documents/users/$(request.auth.uid));
      allow update: if false;
      allow delete: if false;
    }

    match /user_connections/{connectionId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get, create, update, delete: if isSignedIn() && isValidId(connectionId) && (existing().userId == request.auth.uid || incoming().userId == request.auth.uid);
    }
  }
}
